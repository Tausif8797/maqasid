# ---- Server ----
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Local:  mongodb://127.0.0.1:27017/maqasid_bank
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/maqasid_bank?retryWrites=true&w=majority&appName=Cluster0
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/maqasid_bank?retryWrites=true&w=majority&appName=Cluster0

# Optional: comma-separated DNS servers used to resolve the Atlas SRV record.
# Set this if you see "querySrv ECONNREFUSED" (common on Windows/corporate networks).
DNS_SERVERS=8.8.8.8,1.1.1.1

# ---- Authentication ----
# IMPORTANT: replace with a long, random secret in every real environment.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=1d
